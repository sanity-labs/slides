{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreWorkspaces": ["packages/preview", "packages/init-template"],
  "workspaces": {
    ".": {
      "project": []
    },
    "packages/core": {
      "project": ["src/**/*.ts"]
    },
    "packages/mcp": {
      "project": ["src/**/*.ts"]
    },
    "templates/sanity": {
      // ships React component (.tsx) sources alongside .ts modules; widen
      // the project pattern so knip walks both.
      "project": ["src/**/*.ts", "src/**/*.tsx"]
    }
  }
}
