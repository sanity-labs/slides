{
  "name": "@sanity-labs/slides",
  "version": "0.3.0",
  "description": "Brand-locked PowerPoint generation for LLMs. Write a slide template in React; Claude (or any MCP client) writes the deck through the bundled MCP server without drifting on fonts, colors, or layout.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "react",
    "pptx",
    "powerpoint",
    "mcp",
    "model-context-protocol",
    "claude",
    "anthropic",
    "llm",
    "ai",
    "presentations",
    "react-reconciler",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanity-labs/slides.git"
  },
  "homepage": "https://github.com/sanity-labs/slides#readme",
  "bugs": {
    "url": "https://github.com/sanity-labs/slides/issues"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./mcp": "./src/mcp/index.ts",
    "./dev": "./src/dev/index.ts",
    "./scaffold": "./src/scaffold/index.ts",
    "./skill": "./SKILL.md",
    "./package.json": "./package.json"
  },
  "bin": {
    "slidesctl": "./dist/cli.js",
    "slides-dev": "./dist/dev/bin/slides-dev.mjs"
  },
  "files": [
    "dist",
    "src",
    "runtime-tsconfig.json",
    "SKILL.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ./scripts/copy-static-assets.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "verify-bins": "bash scripts/verify-bins.sh",
    "harness": "tsx test/harness/index.ts",
    "harness:verbose": "tsx test/harness/index.ts --verbose",
    "verify": "pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run build && pnpm run test && pnpm run knip && pnpm run verify-bins",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm run build && changeset publish"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@oclif/core": "^4.0.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/react": "^19.0.0",
    "picocolors": "^1.0.0",
    "pptxgenjs": "^4.0.1",
    "tsx": "^4.19.0",
    "typescript": "5.9.3",
    "yoga-layout": "^3.2.1",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "oclif": {
    "bin": "slidesctl",
    "dirname": "slidesctl",
    "commands": "./dist/commands",
    "topicSeparator": " "
  },
  "peerDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.511.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-zoom-pan-pinch": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "vite": "^5.4.0"
  },
  "peerDependenciesMeta": {
    "@tailwindcss/vite": {
      "optional": true
    },
    "@vitejs/plugin-react": {
      "optional": true
    },
    "clsx": {
      "optional": true
    },
    "lucide-react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "react-zoom-pan-pinch": {
      "optional": true
    },
    "tailwindcss": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "clsx": "^2.1.0",
    "eslint": "^9.0.0",
    "knip": "^5.0.0",
    "lucide-react": "^0.511.0",
    "prettier": "^3.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-zoom-pan-pinch": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "vite": "^5.4.0",
    "vitest": "2.1.9"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./mcp": {
        "types": "./dist/mcp/index.d.ts",
        "import": "./dist/mcp/index.js"
      },
      "./dev": {
        "types": "./dist/dev/index.d.ts",
        "import": "./dist/dev/index.js"
      },
      "./scaffold": {
        "types": "./dist/scaffold/index.d.ts",
        "import": "./dist/scaffold/index.js"
      },
      "./skill": "./SKILL.md",
      "./package.json": "./package.json"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.0.0"
}
