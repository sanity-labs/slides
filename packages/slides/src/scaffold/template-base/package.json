{
  "name": "__NAME__",
  "version": "0.0.0",
  "private": true,
  "description": "A react-pptx template.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "slides-dev",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "serve": "react-pptx-mcp serve --template ./dist/index.js",
    "generate": "react-pptx-mcp generate --template ./dist/index.js"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-pptx": "^0.0.0"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "19.2.5",
    "react-pptx": "^0.0.0",
    "react-pptx-dev": "^0.0.0",
    "react-pptx-mcp": "^0.0.0",
    "typescript": "^5.5.0"
  }
}
