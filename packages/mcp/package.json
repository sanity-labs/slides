{
  "name": "react-pptx-mcp",
  "version": "0.0.0",
  "description": "MCP server + CLI that turns a react-pptx template into a brand-locked PPTX generator for LLMs. Auto-derives MCP tools from a template's component schemas. Ships a generic `react-pptx-mcp` bin and an LLM SKILL.md.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./skill": "./SKILL.md",
    "./package.json": "./package.json"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "react-pptx-mcp": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "SKILL.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.build.json --force",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "react",
    "pptx",
    "powerpoint",
    "mcp",
    "model-context-protocol",
    "claude",
    "anthropic",
    "llm",
    "ai",
    "presentations"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanity-labs/react-pptx.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/sanity-labs/react-pptx/tree/main/packages/mcp#readme",
  "bugs": {
    "url": "https://github.com/sanity-labs/react-pptx/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "react": "^19.0.0",
    "react-pptx": "workspace:*",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./skill": "./SKILL.md",
      "./package.json": "./package.json"
    }
  }
}
