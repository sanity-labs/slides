{
  "name": "__NAME__",
  "version": "0.0.0",
  "private": true,
  "description": "A @sanity-labs/slides template.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "slides-dev",
    "build": "tsc -p tsconfig.build.json && node -e \"require('node:fs').cpSync('src/SKILL.md','dist/SKILL.md')\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "serve": "slidesctl serve --template ./dist/index.js",
    "generate": "slidesctl generate --template ./dist/index.js"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "dependencies": {
    "@sanity-labs/slides": "^0.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "typescript": "^5.5.0"
  }
}
