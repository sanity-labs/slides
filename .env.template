# Copy this file to `.env` and fill in real values. The `.env` file is
# git-ignored; never commit secrets. The harness auto-loads `.env` from the
# repo root when you run `pnpm harness`.

# Required: Anthropic API key for `pnpm harness`. Get one at
# https://console.anthropic.com/. The harness makes real API calls and
# spends real credits, so guard this like any production secret.
ANTHROPIC_API_KEY=

# Optional: override the model the harness drives. Defaults to claude-opus-4-7.
# Any model id from the Anthropic API works (claude-sonnet-4-6, claude-haiku-4-5, …).
# HARNESS_MODEL=claude-opus-4-7
